# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# local SSE playback recordings (raw agent stream captures — not committed).
# The small sample `default.txt` IS committed; larger real captures are local-only.
/public/recordings/*
!/public/recordings/default.txt

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# …but the non-secret template IS tracked as the config reference (docs-as-code).
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
