# Non-secret config template — copy to `.env` (gitignored) and adjust locally, or let
# docker-compose.yml's `env_file: frontend/.env` pick it up for the container. Every
# key here is `NEXT_PUBLIC_*`: it reaches the browser bundle, so it must never hold a
# secret (Principle II). See docs/design-docs/customization-and-theming.md.

# Non-secret endpoint selection only — the sole knob that reaches the browser bundle.
# Default = the same-origin dev mock route `/api/chat` (served by `next dev`; streams
# a recorded response with zero Databricks access). Override with a real agent/proxy
# URL for a live backend; leave empty for the "no endpoint" inline notice.
# Trailing slash matches `trailingSlash: true` (avoids a 308 redirect on POST).
#
# A root-relative value like `/api/chat` is resolved against the app's OWN base path at
# runtime, so one static build works at any mount point: hosted under
# `domain.com/path/proxy/`, `/api/chat` reaches `domain.com/path/proxy/api/chat/`, not
# the domain root. Use a full `https://…` URL for a cross-origin backend. (Same rule for
# the HISTORY/FEEDBACK/AGENTS URLs below.)
NEXT_PUBLIC_CHAT_ENDPOINT_URL=/api/chat

# Optional host-provided REST endpoints (all independent; unset ⇒ local fallback).
NEXT_PUBLIC_HISTORY_API_URL=
NEXT_PUBLIC_FEEDBACK_API_URL=
NEXT_PUBLIC_AGENTS_API_URL=

# Empty-state sample prompts: a JSON array of strings, e.g.
# '["Summarize this doc","Write a SQL query"]'. Unset/malformed ⇒ no samples.
NEXT_PUBLIC_SAMPLE_PROMPTS=

# Show the composer's attach/upload button ("1"/"true"/"yes" ⇒ on). Default off.
NEXT_PUBLIC_ENABLE_UPLOAD=

# File-picker accept list, comma-separated mime patterns/extensions, e.g.
# "image/*,application/pdf,.csv". Unset/blank ⇒ images only.
NEXT_PUBLIC_UPLOAD_ACCEPT=

# Max size per attached file, in MB. Unset/invalid ⇒ built-in default (10 MB).
NEXT_PUBLIC_UPLOAD_MAX_SIZE_MB=

# Developer/test Dev tools + Replay mode ("1"/"true"/"yes" ⇒ on). Default off — a demo
# deploy sets it, a customer-facing deploy leaves it blank. Non-secret selector (FR-026).
NEXT_PUBLIC_DEV_TOOLS=
